{
  "compilerOptions": {
    "target": "es2019",
    "lib": ["ES2019", "dom"],
    "module": "commonjs",
    "moduleResolution": "node",
    "experimentalDecorators": true,
    "esModuleInterop": true,
    "sourceMap": true,
    "strict": true,
    "declaration": true,
    "outDir": "dist",
    "typeRoots": [
      "./types",
      "./node_modules/@types"
    ]
  },
  "include": ["src", "./test/parser/setup.ts"],
  "exclude": ["node_modules"]
}
